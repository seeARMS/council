{
  "name": "council-web",
  "version": "0.0.0",
  "private": true,
  "description": "Landing page for council. Styling uses a vendored Tailwind browser runtime documented in public/vendor/README.md.",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "astro": "^6.2.0",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "x-vendored-assets": {
    "tailwind-browser-runtime": {
      "path": "public/vendor/tailwindcss.js",
      "sha256": "176e894661aa9cdc9a5cba6c720044cbbf7b8bd80d1c9a142a7c24b1b6c50d15",
      "docs": "public/vendor/README.md"
    }
  }
}
