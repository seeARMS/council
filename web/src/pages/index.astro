---
import { Font, Image } from "astro:assets";
import cliPackage from "../../../cli/package.json";
import councilNavLogo from "../assets/council-64.png";
import councilHeroLogo from "../assets/council-256.png";
import codexLogo from "../assets/agent-logos/codex.png";
import claudeLogo from "../assets/agent-logos/claude.png";
import {
  authorName,
  defaultSiteUrl,
  description,
  examplePrompt,
  ogImageAlt,
  ogImagePath,
  siteName,
  title,
  xHandle,
} from "../site-meta.js";
import "../styles/global.css";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? defaultSiteUrl;
const pageUrl = `${siteUrl}/`;
const metaImage = `${siteUrl}${ogImagePath}`;
const repoUrl = cliPackage.repository.url.replace(/^git\+/, "").replace(/\.git$/, "");
const docsUrl = `${repoUrl}/blob/main/cli/README.md`;
const licenseUrl = `${repoUrl}/blob/main/LICENSE`;
const npmUrl = `https://www.npmjs.com/package/${cliPackage.name}`;
const xUrl = "https://x.com/colinarms";
const GA_MEASUREMENT_ID = "G-VLG18DVXN5";
const robotsContent = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
    description,
    inLanguage: "en-US",
    publisher: {
      "@type": "Person",
      name: authorName,
      url: xUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: siteName,
    url: pageUrl,
    description,
    mainEntityOfPage: pageUrl,
    applicationCategory: "DeveloperApplication",
    applicationSubCategory: "Command-line interface",
    softwareVersion: cliPackage.version,
    downloadUrl: npmUrl,
    installUrl: npmUrl,
    softwareHelp: {
      "@type": "CreativeWork",
      url: docsUrl,
    },
    runtimePlatform: "Node.js >= 22",
    softwareRequirements: "At least one authenticated Codex, Claude, or Gemini CLI installed locally",
    license: licenseUrl,
    image: metaImage,
    screenshot: [
      `${siteUrl}/screenshots/screenshot-1.jpg`,
      `${siteUrl}/screenshots/screenshot-3.jpg`,
    ],
    author: {
      "@type": "Person",
      name: authorName,
      url: xUrl,
    },
    isAccessibleForFree: true,
    keywords: "Codex, Claude, Gemini, AI coding CLI, developer tools, multi-agent CLI",
    featureList: [
      "Runs Codex, Claude, and Gemini in parallel",
      "Synthesizes one answer across multiple model outputs",
      "Surfaces disagreements instead of hiding them",
      "Supports interactive terminal, JSON, JSONL, and headless modes",
      "Uses the subscriptions you already pay for",
    ],
    sameAs: [repoUrl, npmUrl, xUrl],
  },
]);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/council.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#18181b" media="(prefers-color-scheme: dark)" />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="author" content={authorName} />
    <meta name="creator" content={authorName} />
    <meta name="publisher" content={authorName} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <link rel="canonical" href={pageUrl} />
    <link rel="sitemap" type="application/xml" href={`${siteUrl}/sitemap.xml`} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:image:secure_url" content={metaImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={xHandle} />
    <meta name="twitter:creator" content={xHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-geist-mono" preload />
    <script type="application/ld+json" set:html={structuredData}></script>

    <script is:inline>
      const root = document.documentElement;
      const darkModeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
      const THEME_TRANSITION_MS = 280;
      let themeTransitionTimeout;

      // Start entrance motion only after the first paint so production and dev behave the same.
      if (window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
        root.classList.add("motion-pending");
        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => {
            root.classList.remove("motion-pending");
            root.classList.add("motion-ready");
          });
        });
      }

      updateMode();
      darkModeMediaQuery.addEventListener("change", () => {
        if (localStorage.getItem("theme")) {
          updateMode();
          return;
        }

        startThemeTransition();
        window.requestAnimationFrame(() => {
          updateMode();
        });
      });

      function updateMode() {
        const saved = localStorage.getItem("theme");
        const isDark = saved === "dark" || (!saved && darkModeMediaQuery.matches);

        root.classList.toggle("dark", isDark);
        root.style.colorScheme = isDark ? "dark" : "light";
      }

      function startThemeTransition() {
        root.classList.add("theme-switching");
        window.clearTimeout(themeTransitionTimeout);
        themeTransitionTimeout = window.setTimeout(() => {
          root.classList.remove("theme-switching");
        }, THEME_TRANSITION_MS);
      }

      window.toggleDarkMode = function () {
        const isDark = root.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "light" : "dark");
        startThemeTransition();
        window.requestAnimationFrame(() => {
          updateMode();
        });
      };
    </script>
    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      :root {
        font-feature-settings: "cv02", "cv03", "cv04", "cv11";
      }

      .theme-switching,
      .theme-switching *,
      .theme-switching *::before,
      .theme-switching *::after {
        transition-property:
          background-color,
          border-color,
          color,
          fill,
          stroke,
          opacity,
          box-shadow,
          transform,
          filter !important;
        transition-duration: 280ms !important;
        transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1) !important;
      }

      .command-shell {
        position: relative;
        overflow: hidden;
        background: #09090b;
        border-color: rgba(24, 24, 27, 0.95);
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.14),
          0 10px 28px rgba(15, 23, 42, 0.16),
          0 28px 64px rgba(15, 23, 42, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.06);
        transition: box-shadow 320ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .command-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(39, 39, 42, 0.22), rgba(9, 9, 11, 0));
        pointer-events: none;
      }

      .command-shell:hover {
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.14),
          0 14px 36px rgba(15, 23, 42, 0.20),
          0 32px 72px rgba(15, 23, 42, 0.22),
          inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }

      .agent-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
        padding: 0.5rem 0.85rem;
        border: 1px solid rgba(228, 228, 231, 1);
        border-radius: 9999px;
        background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.95),
          0 1px 2px rgba(15, 23, 42, 0.06),
          0 10px 24px rgba(15, 23, 42, 0.06);
        font-size: 0.95rem;
        line-height: 1;
        transition:
          transform 220ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 200ms ease,
          background 200ms ease,
          box-shadow 220ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .agent-chip:hover {
        transform: translateY(-1px);
        border-color: rgba(212, 212, 216, 1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 1),
          0 2px 4px rgba(15, 23, 42, 0.07),
          0 16px 32px rgba(15, 23, 42, 0.10);
      }

      .agent-chip img {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
        object-fit: contain;
      }

      .agent-chip .agent-chip-codex-logo {
        width: 1.08rem;
        height: 1.08rem;
        border-radius: 0.3em;
      }

      .agent-chip-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
      }

      .dark .agent-chip {
        border-color: rgba(63, 63, 70, 0.95);
        background: linear-gradient(180deg, rgba(39, 39, 42, 0.95) 0%, rgba(24, 24, 27, 0.95) 100%);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.06),
          0 1px 2px rgba(0, 0, 0, 0.30),
          0 10px 24px rgba(0, 0, 0, 0.24);
      }

      .dark .agent-chip:hover {
        border-color: rgba(82, 82, 91, 1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.08),
          0 2px 4px rgba(0, 0, 0, 0.32),
          0 16px 32px rgba(0, 0, 0, 0.32);
      }

      .video-glow {
        position: absolute;
        inset: -22% -16% -16% -16%;
        border-radius: 9999px;
        pointer-events: none;
        background:
          radial-gradient(55% 65% at 70% 30%, rgba(249, 115, 22, 0.55), rgba(249, 115, 22, 0.14) 45%, rgba(249, 115, 22, 0) 78%),
          radial-gradient(50% 60% at 30% 75%, rgba(37, 99, 235, 0.45), rgba(37, 99, 235, 0.10) 50%, rgba(37, 99, 235, 0) 78%);
        filter: blur(36px);
        opacity: 1;
        z-index: 0;
      }

      .dark .video-glow {
        background:
          radial-gradient(55% 65% at 70% 30%, rgba(251, 146, 60, 0.55), rgba(251, 146, 60, 0.10) 45%, rgba(251, 146, 60, 0) 78%),
          radial-gradient(50% 60% at 30% 75%, rgba(96, 165, 250, 0.40), rgba(96, 165, 250, 0.08) 50%, rgba(96, 165, 250, 0) 78%);
        opacity: 0.95;
      }

      .hero-video {
        position: relative;
        width: 100%;
        max-width: 32rem;
        border-radius: 1.25rem;
        overflow: hidden;
        border: 1px solid rgba(228, 228, 231, 0.95);
        background: linear-gradient(180deg, #ffffff, #f7f7f8);
        box-shadow:
          0 1px 2px rgba(15, 23, 42, 0.06),
          0 12px 28px rgba(15, 23, 42, 0.08),
          0 32px 64px rgba(15, 23, 42, 0.10);
        z-index: 1;
      }

      .dark .hero-video {
        border-color: rgba(63, 63, 70, 0.7);
        background: linear-gradient(180deg, #18181b, #0c0d10);
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.32),
          0 12px 28px rgba(0, 0, 0, 0.32),
          0 32px 64px rgba(0, 0, 0, 0.42);
      }

      .hero-video > video {
        display: block;
        width: 100%;
        height: auto;
      }

      .section-divider {
        height: 1px;
        max-width: 36rem;
        margin: 0 auto;
        background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.32) 35%, rgba(249, 115, 22, 0.32) 65%, transparent);
      }

      .dark .section-divider {
        background: linear-gradient(90deg, transparent, rgba(96, 165, 250, 0.36) 35%, rgba(251, 146, 60, 0.36) 65%, transparent);
      }

      .features-dl > div {
        position: relative;
      }

      .features-dl dt {
        position: relative;
        padding-left: 1.4rem;
      }

      .features-dl dt::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.42rem;
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 9999px;
        background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);
        box-shadow:
          0 0 0 4px rgba(59, 130, 246, 0.12),
          0 1px 2px rgba(37, 99, 235, 0.30);
      }

      .features-dl dd {
        padding-left: 1.4rem;
      }

      .features-dl dd code {
        padding: 0.08rem 0.32rem;
        border-radius: 0.32rem;
        background: rgba(244, 244, 245, 1);
        border: 1px solid rgba(228, 228, 231, 1);
        color: #18181b;
        font-size: 0.85em;
      }

      .dark .features-dl dd code {
        background: rgba(39, 39, 42, 0.7);
        border-color: rgba(63, 63, 70, 0.7);
        color: #e4e4e7;
      }

      .dark .features-dl dt::before {
        background: linear-gradient(135deg, #93c5fd 0%, #3b82f6 100%);
        box-shadow:
          0 0 0 4px rgba(96, 165, 250, 0.16),
          0 1px 2px rgba(0, 0, 0, 0.30);
      }

    </style>
  </head>
  <body class="overflow-x-hidden bg-white text-zinc-800 antialiased dark:bg-[#0b0d12] dark:text-zinc-200">
    <nav class="relative z-20 backdrop-blur-md transition-colors">
      <div class="stagger-fade-group max-w-6xl mx-auto px-6 py-4 flex items-center justify-between text-sm" style="--stagger-fade-base-delay: 20ms;">
        <a href="/" class="flex items-center gap-2 text-zinc-950 font-medium transition-opacity hover:opacity-80 dark:text-zinc-100">
          <Image
            src={councilNavLogo}
            alt=""
            loading="eager"
            class="size-6 [filter:drop-shadow(0_2px_4px_rgb(15_23_42/0.18))]"
          />
          Council
        </a>
        <div class="flex items-center gap-5 text-zinc-500 dark:text-zinc-400">
          <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">GitHub</a>
          <button
            type="button"
            onclick="toggleDarkMode()"
            aria-label="Toggle dark mode"
            class="relative flex h-8 w-8 items-center justify-center text-zinc-500 transition-colors duration-200 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
          >
            <svg class="absolute h-4 w-4 rotate-90 scale-0 opacity-0 transition-all duration-300 dark:rotate-0 dark:scale-100 dark:opacity-100" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
            </svg>
            <svg class="absolute h-4 w-4 rotate-0 scale-100 opacity-100 transition-all duration-300 dark:rotate-90 dark:scale-0 dark:opacity-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="relative">
      <section class="relative pt-12 pb-8 md:pt-16 md:pb-12">
        <div class="relative max-w-6xl mx-auto px-6">
          <div class="grid items-center gap-12 md:grid-cols-2 md:gap-10 lg:gap-16">
            <div class="text-center md:text-left">
              <Image
                src={councilHeroLogo}
                alt=""
                loading="eager"
                fetchpriority="high"
                class="stagger-fade size-16 mx-auto md:mx-0 mb-6 [filter:drop-shadow(0_12px_24px_rgb(37_99_235/0.22))_drop-shadow(0_4px_8px_rgb(15_23_42/0.15))]"
                style="--stagger-fade-delay: 70ms;"
              />
              <h1 class="stagger-fade text-4xl sm:text-5xl md:text-[3.5rem] lg:text-6xl font-semibold tracking-[-0.025em] leading-[1.04] text-zinc-950 text-balance max-w-[18ch] mx-auto md:mx-0 dark:text-zinc-50" style="--stagger-fade-delay: 125ms;">
                Ask three agents.
                <span class="block mt-2 sm:mt-3">Get one answer.</span>
              </h1>
              <p class="stagger-fade mt-6 text-lg leading-[1.55] text-zinc-600 text-pretty max-w-[48ch] mx-auto md:mx-0 dark:text-zinc-400" style="--stagger-fade-delay: 180ms;">
                Council runs Codex, Claude, and Gemini in parallel against the same prompt and synthesizes their responses &mdash; using the subscriptions you already pay for.
              </p>
              <div class="stagger-fade mt-8 space-y-8" style="--stagger-fade-delay: 235ms;">
                <div class="stagger-fade-group space-y-3" style="--stagger-fade-base-delay: 260ms;">
                  <p class="text-xs font-mono uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500">
                    Works with
                  </p>
                  <div class="agent-chip-row justify-center md:justify-start text-zinc-950 font-medium dark:text-zinc-100" aria-label="Supported agents">
                    <span class="agent-chip">
                      <Image src={codexLogo} alt="" aria-hidden="true" width={36} height={36} class="agent-chip-codex-logo" />
                      Codex
                    </span>
                    <span class="agent-chip">
                      <Image src={claudeLogo} alt="" aria-hidden="true" width={32} height={32} />
                      Claude
                    </span>
                    <span class="agent-chip">
                      <img src="/agent-logos/gemini.svg" alt="" aria-hidden="true" />
                      Gemini
                    </span>
                  </div>
                </div>
                <div class="stagger-fade-group space-y-4" style="--stagger-fade-base-delay: 320ms;">
                  <div
                    class="command-shell rounded-2xl border text-left"
                    data-command-box
                    data-copy-text={`npx ${cliPackage.name} ${examplePrompt}`}
                  >
                    <div class="relative z-10 flex items-center gap-3 px-5 py-4 sm:px-6 sm:py-5">
                      <code class="flex-1 min-w-0 font-mono text-sm sm:text-[0.95rem] leading-7 text-zinc-100 break-words">
                        <span class="select-none text-zinc-600">$</span>
                        <span class="text-zinc-500"> npx</span>
                        <span class="text-zinc-300"> {cliPackage.name}</span>
                        <span class="text-zinc-100"> {examplePrompt}</span>
                      </code>
                      <button
                        type="button"
                        class="shrink-0 inline-flex items-center gap-1.5 rounded-md bg-white/5 px-2.5 py-1.5 font-mono text-xs text-zinc-300 transition-colors hover:bg-white/10 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30"
                        data-copy-command
                        aria-label="Copy command"
                      >
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="size-3.5">
                          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                        <span data-copy-label>Copy</span>
                      </button>
                    </div>
                  </div>
                  <div class="relative z-10 flex flex-col items-center justify-between gap-3 text-sm text-zinc-500 dark:text-zinc-400 sm:flex-row">
                    <p>Free and open source. MIT licensed.</p>
                    <a
                      href={repoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="GitHub"
                      class="inline-flex items-center text-zinc-500 transition-colors hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-zinc-100"
                    >
                      <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-current">
                        <path d="M12 .297a12 12 0 0 0-3.79 23.39c.6.11.82-.258.82-.577v-2.234c-3.338.726-4.042-1.61-4.042-1.61a3.182 3.182 0 0 0-1.338-1.756c-1.093-.747.084-.732.084-.732a2.52 2.52 0 0 1 1.84 1.237 2.554 2.554 0 0 0 3.49.996 2.553 2.553 0 0 1 .762-1.6c-2.665-.304-5.466-1.334-5.466-5.932a4.64 4.64 0 0 1 1.235-3.22 4.31 4.31 0 0 1 .117-3.176s1.008-.322 3.3 1.23a11.46 11.46 0 0 1 6.006 0c2.292-1.552 3.297-1.23 3.297-1.23a4.31 4.31 0 0 1 .12 3.176 4.63 4.63 0 0 1 1.233 3.22c0 4.61-2.805 5.625-5.478 5.922a2.862 2.862 0 0 1 .814 2.222v3.293c0 .321.216.694.825.576A12 12 0 0 0 12 .297" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <div class="stagger-fade relative" style="--stagger-fade-delay: 320ms;">
              <div class="video-glow" aria-hidden="true"></div>
              <div class="hero-video mx-auto md:ml-auto md:mr-0">
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  poster="/hero/council-hero.jpg"
                  aria-hidden="true"
                  tabindex="-1"
                  data-hero-video
                >
                  <source src="/hero/council-hero.av1.mp4" type='video/mp4; codecs="av01.0.08M.08"' />
                  <source src="/hero/council-hero.mp4" type='video/mp4; codecs="avc1.640029"' />
                </video>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="max-w-6xl mx-auto px-6"><div class="section-divider" aria-hidden="true"></div></div>

      <section class="pt-12 pb-24 md:pt-16 md:pb-28">
        <div class="max-w-6xl mx-auto px-6">
          <div class="stagger-fade-group" style="--stagger-fade-base-delay: 420ms;">
            <p class="mx-auto max-w-3xl text-center text-lg leading-8 text-zinc-700 text-balance dark:text-zinc-300">
              Three models, three sets of blind spots. Council runs them in parallel and surfaces where they agree, where they don&apos;t, and where one of them is probably wrong.
            </p>
            <div class="mt-16 max-w-3xl mx-auto md:mt-20">
              <h2 class="font-mono text-xs tracking-[0.18em] uppercase text-zinc-500 mb-6 dark:text-zinc-500">Features</h2>
              <dl class="features-dl stagger-fade-group space-y-6 text-sm" style="--stagger-fade-base-delay: 510ms;">
                <div>
                  <dt class="text-base font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">Works with what you&apos;ve already got</dt>
                  <dd class="mt-2 leading-relaxed text-zinc-600 dark:text-zinc-400">Detects <code>codex</code>, <code>claude</code>, and <code>gemini</code> on your <code>PATH</code> and runs whichever subset is there. Override with <code>COUNCIL_*_BIN</code> if your binaries live somewhere unusual.</dd>
                </div>
                <div>
                  <dt class="text-base font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">Won&apos;t touch your code</dt>
                  <dd class="mt-2 leading-relaxed text-zinc-600 dark:text-zinc-400">Each CLI runs in its plan or read-only mode. Nothing on disk changes unless you opt in.</dd>
                </div>
                <div>
                  <dt class="text-base font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">See where they disagree</dt>
                  <dd class="mt-2 leading-relaxed text-zinc-600 dark:text-zinc-400">One answer drawn from all three responses, with real disagreements surfaced instead of averaged away. If the lead summarizer is down, the next one takes over.</dd>
                </div>
                <div>
                  <dt class="text-base font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">Watch them think, ask follow-ups</dt>
                  <dd class="mt-2 leading-relaxed text-zinc-600 dark:text-zinc-400">Each model streams in place, with a heartbeat on the slow ones. Press a number to expand a full answer. Type to ask a follow-up &mdash; the next turn carries the prior context.</dd>
                </div>
                <div>
                  <dt class="text-base font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">Drops into any pipeline</dt>
                  <dd class="mt-2 leading-relaxed text-zinc-600 dark:text-zinc-400">Pipe stdin with <code>echo &quot;...&quot; | council</code>, get structured output with <code>--json</code> or <code>--json-stream</code>, skip the dashboard with <code>--headless</code>, or import <code>runCouncil()</code> directly in Node.</dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
      </section>
    </main>

