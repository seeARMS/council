---
import { Font, Image } from "astro:assets";
import cliPackage from "../../../cli/package.json";
import councilNavLogo from "../assets/council-64.png";
import councilHeroLogo from "../assets/council-256.png";
import codexLogo from "../assets/agent-logos/codex.png";
import claudeLogo from "../assets/agent-logos/claude.png";
import "../styles/global.css";

const site = Astro.site?.toString().replace(/\/$/, "") ?? "";
const siteUrl = site || "https://council.armstr.ng";
const pageUrl = `${siteUrl}/`;
const metaImage = `${siteUrl}/meta.jpg`;
const siteName = "Council";
const authorName = "Colin Armstrong";
const xHandle = "@colinarms";
const repoUrl = cliPackage.repository.url.replace(/^git\+/, "").replace(/\.git$/, "");
const docsUrl = `${repoUrl}/blob/main/cli/README.md`;
const licenseUrl = `${repoUrl}/blob/main/LICENSE`;
const npmUrl = `https://www.npmjs.com/package/${cliPackage.name}`;
const xUrl = "https://x.com/colinarms";
const title = "Council: Compare Codex, Claude, and Gemini in One CLI";
const description =
  "Council is an open-source CLI that runs Codex, Claude, and Gemini in parallel on the same prompt, synthesizes one answer, and highlights disagreements.";
const examplePrompt = "review this migration plan";
const GA_MEASUREMENT_ID = "G-VLG18DVXN5";
const robotsContent = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
    description,
    inLanguage: "en-US",
    publisher: {
      "@type": "Person",
      name: authorName,
      url: xUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: siteName,
    url: pageUrl,
    description,
    mainEntityOfPage: pageUrl,
    applicationCategory: "DeveloperApplication",
    applicationSubCategory: "Command-line interface",
    softwareVersion: cliPackage.version,
    downloadUrl: npmUrl,
    installUrl: npmUrl,
    softwareHelp: {
      "@type": "CreativeWork",
      url: docsUrl,
    },
    runtimePlatform: "Node.js >= 22",
    softwareRequirements: "At least one authenticated Codex, Claude, or Gemini CLI installed locally",
    license: licenseUrl,
    image: metaImage,
    screenshot: [
      `${siteUrl}/screenshots/screenshot-1.jpg`,
      `${siteUrl}/screenshots/screenshot-3.jpg`,
    ],
    author: {
      "@type": "Person",
      name: authorName,
      url: xUrl,
    },
    isAccessibleForFree: true,
    keywords: "Codex, Claude, Gemini, AI coding CLI, developer tools, multi-agent CLI",
    featureList: [
      "Runs Codex, Claude, and Gemini in parallel",
      "Synthesizes one answer across multiple model outputs",
      "Surfaces disagreements instead of hiding them",
      "Supports interactive terminal, JSON, JSONL, and headless modes",
      "Uses the subscriptions you already pay for",
    ],
    sameAs: [repoUrl, npmUrl, xUrl],
  },
]);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/council.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#18181b" media="(prefers-color-scheme: dark)" />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="author" content={authorName} />
    <meta name="creator" content={authorName} />
    <meta name="publisher" content={authorName} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <link rel="canonical" href={pageUrl} />
    <link rel="sitemap" type="application/xml" href={`${siteUrl}/sitemap.xml`} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image:alt" content="Council CLI homepage for comparing Codex, Claude, and Gemini on the same prompt." />
    <meta property="og:image" content={metaImage} />
    <meta property="og:image:secure_url" content={metaImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={xHandle} />
    <meta name="twitter:creator" content={xHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImage} />
    <meta name="twitter:image:alt" content="Council CLI homepage for comparing Codex, Claude, and Gemini on the same prompt." />

    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-geist-mono" preload />
    <script type="application/ld+json" set:html={structuredData}></script>

    <script is:inline>
      const darkModeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
      const THEME_TRANSITION_MS = 280;
      let themeTransitionTimeout;

      updateMode();
      darkModeMediaQuery.addEventListener("change", () => {
        if (localStorage.getItem("theme")) {
          updateMode();
          return;
        }

        startThemeTransition();
        window.requestAnimationFrame(() => {
          updateMode();
        });
      });

      function updateMode() {
        const saved = localStorage.getItem("theme");
        const isDark = saved === "dark" || (!saved && darkModeMediaQuery.matches);

        document.documentElement.classList.toggle("dark", isDark);
        document.documentElement.style.colorScheme = isDark ? "dark" : "light";
      }

      function startThemeTransition() {
        document.documentElement.classList.add("theme-switching");
        window.clearTimeout(themeTransitionTimeout);
        themeTransitionTimeout = window.setTimeout(() => {
          document.documentElement.classList.remove("theme-switching");
        }, THEME_TRANSITION_MS);
      }

      window.toggleDarkMode = function () {
        const isDark = document.documentElement.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "light" : "dark");
        startThemeTransition();
        window.requestAnimationFrame(() => {
          updateMode();
        });
      };
    </script>
    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      :root {
        font-feature-settings: "cv02", "cv03", "cv04", "cv11";
      }

      .theme-switching,
      .theme-switching *,
      .theme-switching *::before,
      .theme-switching *::after {
        transition-property:
          background-color,
          border-color,
          color,
          fill,
          stroke,
          opacity,
          box-shadow,
          transform,
          filter !important;
        transition-duration: 280ms !important;
        transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1) !important;
      }

      .command-shell {
        position: relative;
        overflow: hidden;
        background: #09090b;
        border-color: rgba(24, 24, 27, 0.95);
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.12),
          0 8px 24px rgba(0, 0, 0, 0.12),
          0 24px 60px rgba(0, 0, 0, 0.18),
          inset 0 1px 0 rgba(255, 255, 255, 0.06);
      }

      .command-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(39, 39, 42, 0.22), rgba(9, 9, 11, 0));
        pointer-events: none;
      }

      .agent-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin: 0;
        padding: 0.45rem 0.78rem;
        border: 1px solid rgba(212, 212, 216, 0.9);
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.95);
        box-shadow:
          0 1px 2px rgba(15, 23, 42, 0.05),
          0 10px 30px rgba(15, 23, 42, 0.06);
        font-size: 0.95rem;
        line-height: 1;
        transition:
          border-color 200ms ease,
          background-color 200ms ease,
          box-shadow 200ms ease;
      }

      .agent-chip img {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
        object-fit: contain;
      }

      .agent-chip .agent-chip-codex-logo {
        width: 1.08rem;
        height: 1.08rem;
        border-radius: 0.3em;
      }

      .agent-chip-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
      }

      .dark .agent-chip {
        border-color: rgba(63, 63, 70, 0.95);
        background: rgba(39, 39, 42, 0.9);
        box-shadow:
          0 1px 2px rgba(0, 0, 0, 0.22),
          0 10px 30px rgba(0, 0, 0, 0.2),
          inset 0 1px 0 rgba(255, 255, 255, 0.04);
      }

      .hero-spotlight {
        position: absolute;
        left: 50%;
        top: 1.5rem;
        width: min(42rem, 78vw);
        height: 24rem;
        transform: translateX(-50%);
        pointer-events: none;
        border-radius: 9999px;
        background:
          radial-gradient(circle at 50% 22%, rgba(84, 111, 181, 0.2), rgba(84, 111, 181, 0.08) 24%, rgba(84, 111, 181, 0.02) 46%, rgba(84, 111, 181, 0) 68%),
          radial-gradient(circle at 50% 30%, rgba(36, 48, 80, 0.12), rgba(36, 48, 80, 0.04) 32%, rgba(36, 48, 80, 0) 60%);
        filter: blur(18px);
        opacity: 0.72;
      }

      .hero-spotlight::after {
        content: "";
        position: absolute;
        inset: 12% 18% 42%;
        border-radius: inherit;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0) 72%);
      }

      .dark .hero-spotlight {
        background:
          radial-gradient(circle at 50% 22%, rgba(111, 145, 226, 0.18), rgba(111, 145, 226, 0.08) 24%, rgba(111, 145, 226, 0.03) 44%, rgba(111, 145, 226, 0) 68%),
          radial-gradient(circle at 50% 28%, rgba(36, 48, 80, 0.36), rgba(36, 48, 80, 0.16) 30%, rgba(36, 48, 80, 0.04) 46%, rgba(36, 48, 80, 0) 64%);
        filter: blur(20px);
        opacity: 0.68;
      }

      .dark .hero-spotlight::after {
        background: radial-gradient(circle, rgba(148, 163, 184, 0.05), rgba(148, 163, 184, 0) 70%);
      }

    </style>
  </head>
  <body class="overflow-x-hidden bg-white text-zinc-800 antialiased dark:bg-zinc-900 dark:text-zinc-200">
    <nav class="relative z-20 bg-white/85 backdrop-blur-sm transition-colors dark:bg-zinc-900/85">
      <div class="stagger-fade-group max-w-4xl mx-auto px-6 py-4 flex items-center justify-between text-sm" style="--stagger-fade-base-delay: 20ms;">
        <a href="/" class="flex items-center gap-2 text-zinc-950 font-medium transition-opacity hover:opacity-80 dark:text-zinc-100">
          <Image
            src={councilNavLogo}
            alt=""
            loading="eager"
            class="size-6 [filter:drop-shadow(0_2px_4px_rgb(15_23_42/0.18))]"
          />
          Council
        </a>
        <div class="flex items-center gap-5 text-zinc-500 dark:text-zinc-400">
          <a href={docsUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">README</a>
          <a href={npmUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">npm</a>
          <a href={repoUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">GitHub</a>
          <button
            type="button"
            onclick="toggleDarkMode()"
            aria-label="Toggle dark mode"
            class="relative flex h-8 w-8 items-center justify-center text-zinc-500 transition-colors duration-200 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
          >
            <svg class="absolute h-4 w-4 rotate-90 scale-0 opacity-0 transition-all duration-300 dark:rotate-0 dark:scale-100 dark:opacity-100" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="5"></circle>
              <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
            </svg>
            <svg class="absolute h-4 w-4 rotate-0 scale-100 opacity-100 transition-all duration-300 dark:rotate-90 dark:scale-0 dark:opacity-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="relative">
      <section class="relative pt-16 pb-6 md:pb-16">
        <div class="hero-spotlight" aria-hidden="true"></div>
        <div class="relative max-w-4xl mx-auto px-6 text-center">
          <Image
            src={councilHeroLogo}
            alt=""
            loading="eager"
            fetchpriority="high"
            class="stagger-fade size-20 mx-auto mb-8 [filter:drop-shadow(0_12px_24px_rgb(36_48_80/0.25))_drop-shadow(0_4px_8px_rgb(15_23_42/0.15))]"
            style="--stagger-fade-delay: 70ms;"
          />
          <h1 class="stagger-fade text-4xl sm:text-5xl font-semibold tracking-tight leading-[1.08] text-zinc-950 text-balance max-w-[18ch] mx-auto dark:text-zinc-100" style="--stagger-fade-delay: 125ms;">
            Ask three agents.
            <span class="block mt-3 sm:mt-4">Get one answer.</span>
          </h1>
          <p class="stagger-fade mt-6 text-lg text-zinc-600 text-pretty max-w-[56ch] mx-auto dark:text-zinc-400" style="--stagger-fade-delay: 180ms;">
            Council runs Codex, Claude, and Gemini in parallel against the same prompt and synthesizes their responses &mdash; using the subscriptions you already pay for.
          </p>
          <div class="stagger-fade mt-8 max-w-2xl mx-auto space-y-8" style="--stagger-fade-delay: 235ms;">
            <div class="stagger-fade-group space-y-3" style="--stagger-fade-base-delay: 260ms;">
              <p class="text-xs font-mono uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500">
                Works with
              </p>
              <div class="agent-chip-row text-zinc-950 font-medium dark:text-zinc-100" aria-label="Supported agents">
                <span class="agent-chip">
                  <Image src={codexLogo} alt="" aria-hidden="true" width={36} height={36} class="agent-chip-codex-logo" />
                  Codex
                </span>
                <span class="agent-chip">
                  <Image src={claudeLogo} alt="" aria-hidden="true" width={32} height={32} />
                  Claude
                </span>
                <span class="agent-chip">
                  <img src="/agent-logos/gemini.svg" alt="" aria-hidden="true" />
                  Gemini
                </span>
              </div>
            </div>
            <div class="stagger-fade-group space-y-4" style="--stagger-fade-base-delay: 320ms;">
              <div class="relative z-10 flex flex-col items-center justify-between gap-3 text-sm text-zinc-500 dark:text-zinc-400 sm:flex-row">
                <p>Free and open source. MIT licensed.</p>
                <a
                  href={repoUrl}
                  aria-label="GitHub"
                  class="inline-flex items-center text-zinc-500 transition-colors hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-zinc-100"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="size-4 fill-current">
                    <path d="M12 .297a12 12 0 0 0-3.79 23.39c.6.11.82-.258.82-.577v-2.234c-3.338.726-4.042-1.61-4.042-1.61a3.182 3.182 0 0 0-1.338-1.756c-1.093-.747.084-.732.084-.732a2.52 2.52 0 0 1 1.84 1.237 2.554 2.554 0 0 0 3.49.996 2.553 2.553 0 0 1 .762-1.6c-2.665-.304-5.466-1.334-5.466-5.932a4.64 4.64 0 0 1 1.235-3.22 4.31 4.31 0 0 1 .117-3.176s1.008-.322 3.3 1.23a11.46 11.46 0 0 1 6.006 0c2.292-1.552 3.297-1.23 3.297-1.23a4.31 4.31 0 0 1 .12 3.176 4.63 4.63 0 0 1 1.233 3.22c0 4.61-2.805 5.625-5.478 5.922a2.862 2.862 0 0 1 .814 2.222v3.293c0 .321.216.694.825.576A12 12 0 0 0 12 .297" />
                  </svg>
                </a>
              </div>
              <div
                class="command-shell rounded-2xl border text-left"
                data-command-box
                data-copy-text={`npx ${cliPackage.name} ${examplePrompt}`}
              >
                <div class="relative z-10 flex items-center gap-3 px-5 py-4 sm:px-6 sm:py-5">
                  <code class="flex-1 min-w-0 font-mono text-sm sm:text-[0.95rem] leading-7 text-zinc-100 break-words">
                    <span class="select-none text-zinc-600">$</span>
                    <span class="text-zinc-500"> npx</span>
                    <span class="text-zinc-300"> {cliPackage.name}</span>
                    <span class="text-zinc-100"> {examplePrompt}</span>
                  </code>
                  <button
                    type="button"
                    class="shrink-0 inline-flex items-center gap-1.5 rounded-md bg-white/5 px-2.5 py-1.5 font-mono text-xs text-zinc-300 transition-colors hover:bg-white/10 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white/30"
                    data-copy-command
                    aria-label="Copy command"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="size-3.5">
                      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    <span data-copy-label>Copy</span>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-20">
        <div class="max-w-3xl mx-auto px-6">
          <div class="stagger-fade-group" style="--stagger-fade-base-delay: 420ms;">
            <p class="mb-4 text-base text-zinc-600 text-pretty dark:text-zinc-400">
              Three models, three sets of blind spots. Council runs them in parallel and surfaces where they agree, where they don&apos;t, and where one of them is probably wrong.
            </p>
            <h2 class="font-mono text-xs tracking-wide uppercase text-zinc-500 mb-6 dark:text-zinc-500">Features</h2>
            <dl class="stagger-fade-group space-y-5 text-sm" style="--stagger-fade-base-delay: 510ms;">
              <div>
                <dt class="font-medium text-zinc-950 dark:text-zinc-100">Works with what you&apos;ve already got</dt>
                <dd class="mt-1 text-zinc-600 dark:text-zinc-400">Detects <code>codex</code>, <code>claude</code>, and <code>gemini</code> on your <code>PATH</code> and runs whichever subset is there. Override with <code>COUNCIL_*_BIN</code> if your binaries live somewhere unusual.</dd>
              </div>
              <div>
                <dt class="font-medium text-zinc-950 dark:text-zinc-100">Won&apos;t touch your code</dt>
                <dd class="mt-1 text-zinc-600 dark:text-zinc-400">Each CLI runs in its plan or read-only mode. Nothing on disk changes unless you opt in.</dd>
              </div>
              <div>
                <dt class="font-medium text-zinc-950 dark:text-zinc-100">See where they disagree</dt>
                <dd class="mt-1 text-zinc-600 dark:text-zinc-400">One answer drawn from all three responses, with real disagreements surfaced instead of averaged away. If the lead summarizer is down, the next one takes over.</dd>
              </div>
              <div>
                <dt class="font-medium text-zinc-950 dark:text-zinc-100">Watch them think, ask follow-ups</dt>
                <dd class="mt-1 text-zinc-600 dark:text-zinc-400">Each model streams in place, with a heartbeat on the slow ones. Press a number to expand a full answer. Type to ask a follow-up &mdash; the next turn carries the prior context.</dd>
              </div>
              <div>
                <dt class="font-medium text-zinc-950 dark:text-zinc-100">Drops into any pipeline</dt>
                <dd class="mt-1 text-zinc-600 dark:text-zinc-400">Pipe stdin with <code>echo &quot;...&quot; | council</code>, get structured output with <code>--json</code> or <code>--json-stream</code>, skip the dashboard with <code>--headless</code>, or import <code>runCouncil()</code> directly in Node.</dd>
              </div>
            </dl>
          </div>
        </div>
      </section>
    </main>

    <footer class="pb-12 pt-8 border-t border-zinc-200 transition-colors dark:border-zinc-800">
      <div class="stagger-fade-group max-w-4xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-zinc-500 dark:text-zinc-400" style="--stagger-fade-base-delay: 620ms;">
        <span>&copy; 2026 Colin Armstrong</span>
        <div class="flex items-center gap-6">
          <a href={repoUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">GitHub</a>
          <a href={docsUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">README</a>
          <a href={licenseUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">License</a>
          <a href={xUrl} class="transition-colors hover:text-zinc-950 dark:hover:text-zinc-100">@colinarms</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const commandBox = document.querySelector("[data-command-box]");
      const copyTargets = commandBox?.querySelectorAll("[data-copy-command]") ?? [];

      if (commandBox) {
        const copyText = commandBox.getAttribute("data-copy-text") || "";
        const copyCommand = async () => {
          try {
            await navigator.clipboard.writeText(copyText);
          } catch {
            const input = document.createElement("input");
            input.value = copyText;
            document.body.appendChild(input);
            input.select();
            document.execCommand("copy");
            input.remove();
          }

          copyTargets.forEach((target) => {
            const labelEl = target.querySelector("[data-copy-label]");
            if (!labelEl) return;
            const original = labelEl.textContent || "Copy";
            labelEl.textContent = "Copied";
            window.setTimeout(() => {
              labelEl.textContent = original;
            }, 1400);
          });
        };

        copyTargets.forEach((target) => {
          target.addEventListener("click", copyCommand);
        });
      }
    </script>

    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID, { page_path: window.location.pathname });
      var s = document.createElement("script");
      s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA_MEASUREMENT_ID;
      s.async = true;
      document.body.appendChild(s);
    </script>
  </body>
</html>
