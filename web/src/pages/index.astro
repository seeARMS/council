    <script is:inline>
      const commandBox = document.querySelector("[data-command-box]");
      const copyTargets = commandBox?.querySelectorAll("[data-copy-command]") ?? [];

      if (commandBox) {
        const copyText = commandBox.getAttribute("data-copy-text") || "";
        const copyCommand = async () => {
          try {
            await navigator.clipboard.writeText(copyText);
          } catch {
            const input = document.createElement("input");
            input.value = copyText;
            document.body.appendChild(input);
            input.select();
            document.execCommand("copy");
            input.remove();
          }

          copyTargets.forEach((target) => {
            const labelEl = target.querySelector("[data-copy-label]");
            if (!labelEl) return;
            const original = labelEl.textContent || "Copy";
            labelEl.textContent = "Copied";
            window.setTimeout(() => {
              labelEl.textContent = original;
            }, 1400);
          });
        };

        copyTargets.forEach((target) => {
          target.addEventListener("click", copyCommand);
        });
      }

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.querySelectorAll("video[data-hero-video]").forEach((video) => {
          video.removeAttribute("autoplay");
          video.removeAttribute("loop");
          video.pause();
        });
      }
    </script>

